#!/bin/sh
# Pre-push hook: runs npm preflight to ensure CI will pass.
# Install: git config core.hooksPath .githooks

echo "🔍 Running pre-push preflight checks..."
npm run preflight
EXIT=$?

if [ $EXIT -ne 0 ]; then
  echo ""
  echo "❌ Preflight failed — push aborted."
  echo "Fix the issues above, commit, and try again."
  exit 1
fi

echo "✅ Preflight passed — pushing."
